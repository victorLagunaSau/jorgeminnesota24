{
  "appId": "com.jorgeminnesota.clientes",
  "appName": "Jorge Minnesota",
  "webDir": "www",
  "server": {
    "allowNavigation": ["jorgeminnesota.duckdns.org"]
  },
  "plugins": {
    "CapacitorHttp": {
      "enabled": false
    },
    "SplashScreen": {
      "launchAutoHide": true,
      "launchShowDuration": 1500,
      "backgroundColor": "#ffffff",
      "showSpinner": false
    },
    "Keyboard": {
      "resize": "body",
      "resizeOnFullScreen": true
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#ffffff"
    }
  }
}
